@model StudentBudgetTracker.Models.Budget

<h2>Edit Budget</h2>

<form method="post" class="add-form">

    <input type="hidden" name="Id" value="@Model.Id" />

    <div class="add-group">
    <label>Date</label>
    <input type="date" name="Date" value="@Model.Date.ToString("yyyy-MM-dd")" />
    </div>

     <div class="add-group">
    <label>Description</label>
    <input type="text" name="Description" value="@Model.Description" />
    </div>

    <div class="add-group">
    <label>Allowance</label>
    <input type="number" name="Allowance" value="@Model.Allowance" />
    </div>

     <div class="add-group">
    <label>Expenses</label>
    <input type="number" name="Expenses" value="@Model.Expenses" />
    </div>

     <div class="add-group">
        <label>Type</label>
        <select name="Category" value="@Model.Category">
            <option>None</option>
            <option>Food</option>
            <option>Transportation</option>
            <option>School</option>

        </select>
    </div>

    <button class="add-btn" type="submit">Save Changes</button>

</form>