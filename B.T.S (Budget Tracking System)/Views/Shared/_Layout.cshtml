<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - B.T.S__Budget_Tracking_System_</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/B.T.S__Budget_Tracking_System_.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <h2>Student Budget Tracking</h2>
        <button class="menu-toggle" id="menuToggle" type="button" aria-label="Toggle navigation">
            ☰
        </button>
        <div class="header-a">
            <a class="" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
            <a class="" asp-area="" asp-controller="Home" asp-action="About">About</a>
            <a class="" asp-area="" asp-controller="Home" asp-action="Settings">Settings</a>
        </div>
    </header>





    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

   



    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
